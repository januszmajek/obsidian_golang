filters:
  or:
    - file.name.contains(this.file.name)
    - created.toString().contains(this.file.name)
    - start.toString().contains(this.file.name)
    - end.toString().contains(this.file.name)
    - file.links.contains(this.file)
properties:
  file.name:
    displayName: Entry
  note.categories:
    displayName: Categories
  note.created:
    displayName: Created
  note.tags:
    displayName: Tags
views:
  - type: table
    name: Daily notes
    filters:
      and:
        - '!tags.contains("monthly")'
        - '!file.tags.contains("weekly")'
        - '!file.tags.contains("daily")'
    order:
      - file.name
      - created
      - categories
      - tags
    sort: []
    columnSize:
      file.name: 354
      note.created: 128
      note.categories: 119
  - type: table
    name: Monthly
    filters:
      and:
        - '!tags.contains("daily")'
        - '!file.tags.contains("weekly")'
        - '!file.tags.contains("monthly")'
        - '!file.tags.contains("yearly")'
    order:
      - file.name
      - categories
      - created
    sort:
      - property: file.name
        direction: DESC
      - property: categories
        direction: ASC
      - property: created
        direction: DESC
    columnSize:
      file.name: 354
      note.categories: 167
  - type: table
    name: Yearly
    filters:
      and:
        - '!tags.contains("daily")'
        - '!tags.contains("monthly")'
        - '!file.tags.contains("weekly")'
    order:
      - file.name
      - categories
      - created
    sort:
      - property: created
        direction: ASC
  - type: table
    name: Weekly
    filters:
      and:
        - '!file.tags.contains("monthly")'
        - '!file.tags.contains("daily")'
        - '!file.tags.contains("weekly")'
        - '!file.tags.contains("yearly")'
    sort:
      - property: created
        direction: ASC
