filters:
  and:
    - '!file.name.contains("Template")'
    - tags.contains("journal")
properties:
  file.name:
    displayName: Entry
  note.created:
    displayName: Created
views:
  - type: table
    name: Table
    groupBy:
      property: created
      direction: DESC
    order:
      - file.name
      - created
    columnSize:
      file.name: 532
